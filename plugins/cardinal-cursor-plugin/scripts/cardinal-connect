#!/usr/bin/env python3
"""Connect Cursor to Cardinal telemetry and MCP.

Runs Cardinal's device-code flow, mints ingest and MCP keys, verifies
both endpoints, writes a managed `mcpServers.cardinal` entry to
`~/.cursor/mcp.json`, and installs managed hooks in
`~/.cursor/hooks.json`. With `--project`, additionally writes
`.cursor/mcp.json` and `.cursor/hooks.json` at the repo root so
Cursor cloud agents (which do not load the user-level home directory)
pick up the same wiring.

Monorepo adapter: the device flow, endpoint probes, and file primitives
come from `cardinal_core` (vendored under ../hooks by build/vendor.py);
the Cursor-specific mcp.json / hooks.json managed-entry writers stay
here. See docs/specs/cursor-parity.md for the full contract.
"""

from __future__ import annotations

import argparse
import json
import os
import shlex
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

PLUGIN_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(PLUGIN_ROOT / "hooks"))
from cardinal_core import deviceflow  # noqa: E402
from cardinal_core.paths import atomic_write, atomic_write_secret, backup  # noqa: E402


def _load_plugin_version() -> str:
    manifest = PLUGIN_ROOT / ".cursor-plugin" / "plugin.json"
    try:
        return json.loads(manifest.read_text(encoding="utf-8")).get("version") or "unknown"
    except (OSError, ValueError):
        return "unknown"


PLUGIN_VERSION = _load_plugin_version()
CLIENT_ID = "cardinal-cursor-plugin"
MCP_SERVER_NAME = "cardinal"

HOOK_SCRIPT = PLUGIN_ROOT / "hooks" / "cardinal-cursor-telemetry.py"

# The identity marker embedded in every managed hook `command` string.
# Disconnect uses substring match on this to identify hook entries the
# plugin owns without needing a custom JSON field Cursor might reject.
HOOK_IDENTITY_MARKER = "cardinal-cursor-plugin"

CURSOR_DIR = Path.home() / ".cursor"
USER_MCP_PATH = CURSOR_DIR / "mcp.json"
USER_HOOKS_PATH = CURSOR_DIR / "hooks.json"
STATE_PATH = CURSOR_DIR / "cardinal.json"
SECRETS_PATH = CURSOR_DIR / "cardinal-secrets.json"
PENDING_PATH = CURSOR_DIR / "cardinal-pending.json"

DEFAULT_POLL_TIMEOUT_SECS = deviceflow.DEFAULT_POLL_TIMEOUT_SECS
DEFAULT_POLL_INTERVAL_SECS = deviceflow.DEFAULT_POLL_INTERVAL_SECS


def load_json_object(path: Path, label: str) -> dict:
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        sys.exit(f"Refusing to write: {label} ({path}) is not valid JSON ({exc}).")
    if not isinstance(data, dict):
        sys.exit(f"Refusing to write: {label} ({path}) is not a JSON object.")
    return data


def write_pending(grant: dict) -> None:
    payload = {
        "verification_uri": grant.get("verification_uri", ""),
        "user_code": grant.get("user_code", ""),
        "expires_in": grant.get("expires_in", DEFAULT_POLL_TIMEOUT_SECS),
        "written_at": datetime.now(timezone.utc).isoformat(),
        "plugin_version": PLUGIN_VERSION,
    }
    PENDING_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write(PENDING_PATH, json.dumps(payload, indent=2) + "\n")


def clear_pending() -> None:
    try:
        PENDING_PATH.unlink()
    except FileNotFoundError:
        pass


# ---------------------------------------------------------------------------
# MCP config (JSON) — mcpServers.cardinal entry
# ---------------------------------------------------------------------------

def build_mcp_entry(mcp_url: str, api_key: str) -> dict:
    """A Cursor MCP entry the plugin owns end-to-end. The `cardinalManaged`
    field is metadata for disconnect — Cursor ignores unknown keys inside
    mcpServers entries."""
    return {
        "url": mcp_url,
        "headers": {"X-CardinalHQ-API-Key": api_key},
        "cardinalManaged": True,
        "cardinalPluginVersion": PLUGIN_VERSION,
    }


def write_mcp_config(path: Path, mcp_url: str, api_key: str) -> Path | None:
    data = load_json_object(path, "mcp.json")
    servers = data.get("mcpServers")
    if not isinstance(servers, dict):
        servers = {}
    existing = servers.get(MCP_SERVER_NAME)
    if isinstance(existing, dict) and not existing.get("cardinalManaged"):
        sys.exit(
            f"Refusing to write because {path} already contains an unmanaged "
            f"mcpServers.{MCP_SERVER_NAME} entry. Remove or rename that entry, then rerun."
        )
    servers[MCP_SERVER_NAME] = build_mcp_entry(mcp_url, api_key)
    data["mcpServers"] = servers

    path.parent.mkdir(parents=True, exist_ok=True)
    backup_path = backup(path)
    atomic_write(path, json.dumps(data, indent=2) + "\n")
    return backup_path


# ---------------------------------------------------------------------------
# Hooks config (JSON v1)
# ---------------------------------------------------------------------------

def managed_hook_command(event_name: str) -> str:
    """Include the plugin identity marker in the command so disconnect
    can recognize entries we own without relying on custom JSON fields."""
    return (
        f"python3 {shlex.quote(str(HOOK_SCRIPT))} "
        f"--event {shlex.quote(event_name)} # {HOOK_IDENTITY_MARKER}"
    )


def managed_hook_entry(event_name: str, timeout: int) -> dict:
    return {
        "command": managed_hook_command(event_name),
        "type": "command",
        "timeout": timeout,
    }


def strip_managed_hooks(data: dict) -> dict:
    hooks = data.get("hooks")
    if not isinstance(hooks, dict):
        data["hooks"] = {}
        return data
    for event_name, entries in list(hooks.items()):
        if not isinstance(entries, list):
            continue
        kept = [
            h for h in entries
            if not (
                isinstance(h, dict)
                and HOOK_IDENTITY_MARKER in str(h.get("command") or "")
            )
        ]
        if kept:
            hooks[event_name] = kept
        else:
            hooks.pop(event_name, None)
    data["hooks"] = hooks
    return data


def write_hooks_config(path: Path) -> Path | None:
    """Write the Cursor hooks.json v1 shape.

    Events registered:
      sessionStart        — initiative-convention + budget standing
      beforeSubmitPrompt  — spend-limits gate + git_state
      postToolUse         — turn_tool + tool_result + notify piggyback
      preCompact          — cardinal.plan_usage (context-window slice)
      stop                — best-effort transcript sweep (no-op; gap D)
      subagentStop        — subagent_usage
      afterAgentResponse  — cardinal.turn_response (text length only)
      afterAgentThought   — cardinal.turn_thought (duration + text len)
    """
    data = strip_managed_hooks(load_json_object(path, "hooks.json"))
    data.setdefault("version", 1)
    hooks = data.setdefault("hooks", {})
    for event, timeout in (
        ("sessionStart", 5),
        ("beforeSubmitPrompt", 5),
        ("postToolUse", 5),
        ("preCompact", 5),
        ("stop", 10),
        ("subagentStop", 5),
        ("afterAgentResponse", 5),
        ("afterAgentThought", 5),
    ):
        hooks.setdefault(event, []).append(managed_hook_entry(event, timeout))
    path.parent.mkdir(parents=True, exist_ok=True)
    backup_path = backup(path)
    atomic_write(path, json.dumps(data, indent=2) + "\n")
    return backup_path


# ---------------------------------------------------------------------------
# Project mode target discovery
# ---------------------------------------------------------------------------

def project_root(cwd: str) -> Path | None:
    """Return the git repository root for `cwd`, or None if not a repo."""
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=2.0,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if out.returncode != 0:
        return None
    root = out.stdout.strip()
    return Path(root) if root else None


# ---------------------------------------------------------------------------
# State + secrets
# ---------------------------------------------------------------------------

def write_secrets(bundle: dict) -> None:
    ingest = bundle.get("ingest") or {}
    mcp = bundle.get("mcp") or {}
    payload = {
        "schema_version": 1,
        "ingest_api_key": ingest.get("api_key"),
        "ingest_api_header": ingest.get("api_header") or "x-cardinalhq-api-key",
        "mcp_api_key": mcp.get("api_key"),
        "written_at": datetime.now(timezone.utc).isoformat(),
    }
    atomic_write_secret(SECRETS_PATH, json.dumps(payload, indent=2) + "\n")


def write_state(
    bundle: dict,
    host: str,
    deployment_env: str,
    telemetry_only: bool,
    installed_project_paths: dict[str, str] | None,
) -> None:
    org = bundle.get("org", {})
    user = bundle.get("user", {})
    mcp = bundle.get("mcp") or {}
    ingest = bundle.get("ingest") or {}
    mode = (
        "telemetry-only" if telemetry_only or not mcp
        else "mcp-only" if not ingest
        else "telemetry-and-mcp"
    )
    state: dict = {
        "schema_version": 1,
        "host": host,
        "mode": mode,
        "org_id": org.get("id"),
        "org_slug": org.get("slug"),
        "user_email": user.get("email"),
        "deployment_environment": deployment_env,
        "plugin_version": PLUGIN_VERSION,
        "written_at": datetime.now(timezone.utc).isoformat(),
        "user_mcp_path": str(USER_MCP_PATH),
        "user_hooks_path": str(USER_HOOKS_PATH),
        "secrets_path": str(SECRETS_PATH),
        "telemetry": {"enabled": bool(ingest)},
    }
    if ingest:
        state["ingest_endpoint"] = ingest.get("endpoint")
        state["ingest_key_id"] = ingest.get("key_id")
        state["ingest_key_prefix"] = (ingest.get("api_key") or "")[:8]
    if mcp:
        state["mcp_url"] = mcp.get("url")
        state["mcp_key_id"] = mcp.get("key_id")
        state["mcp_key_prefix"] = mcp.get("key_prefix") or (mcp.get("api_key") or "")[:8]
        state["mcp_created_at"] = mcp.get("created_at")
    limits = bundle.get("limits")
    if isinstance(limits, dict) and limits.get("status_url"):
        state["limits"] = {
            "status_url": limits["status_url"],
            "enabled": bool(limits.get("enabled", True)),
        }
    if installed_project_paths:
        state["project_install"] = installed_project_paths
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write(STATE_PATH, json.dumps(state, indent=2) + "\n")


# ---------------------------------------------------------------------------
# Orchestration
# ---------------------------------------------------------------------------

def continue_after_grant(args: argparse.Namespace, grant: dict) -> int:
    expires_in = int(grant.get("expires_in") or DEFAULT_POLL_TIMEOUT_SECS)
    interval = int(grant.get("interval") or DEFAULT_POLL_INTERVAL_SECS)
    verification_uri = grant.get("verification_uri") or ""

    print()
    print("Open this URL in your browser to approve Cardinal for Cursor:")
    print(f"  {verification_uri}")
    print()
    print(f"Waiting up to {expires_in // 60} minute(s) for browser approval...")

    try:
        bundle = deviceflow.poll_device_token(
            args.host, grant["device_code"], CLIENT_ID, interval, expires_in
        )
    except deviceflow.DeviceFlowError as exc:
        sys.exit(str(exc))
    org = bundle.get("org", {})
    user = bundle.get("user", {})
    ingest = bundle.get("ingest")
    mcp = bundle.get("mcp")

    if not ingest:
        sys.exit("Cardinal did not return an ingest credential. Check the requested scopes.")
    if not args.telemetry_only and not mcp:
        sys.exit("Cardinal did not return an MCP credential. Check the requested scopes.")

    deployment_env = args.deployment_env or deviceflow.derive_deployment_env(args.host)

    # Resolve project install targets if --project was requested.
    project_paths: dict[str, str] | None = None
    if args.project:
        root = project_root(os.getcwd())
        if root is None:
            sys.exit(
                "cardinal-connect --project must run inside a git working "
                "tree so it can locate the project's .cursor directory."
            )
        project_mcp = root / ".cursor" / "mcp.json"
        project_hooks = root / ".cursor" / "hooks.json"
        project_paths = {
            "root": str(root),
            "mcp_path": str(project_mcp),
            "hooks_path": str(project_hooks),
        }

    if args.dry_run:
        print(json.dumps(
            {
                "org": org,
                "user": user,
                "deployment_env": deployment_env,
                "would_write": {
                    "user_mcp": str(USER_MCP_PATH) if mcp else None,
                    "user_hooks": str(USER_HOOKS_PATH),
                    "project_mcp": project_paths["mcp_path"] if project_paths and mcp else None,
                    "project_hooks": project_paths["hooks_path"] if project_paths else None,
                    "state": str(STATE_PATH),
                    "secrets": str(SECRETS_PATH),
                    "ingest_endpoint": ingest.get("endpoint"),
                    "mcp_url": (mcp or {}).get("url"),
                },
            },
            indent=2,
        ))
        return 0

    ok, msg = deviceflow.verify_ingest_reachable(ingest)
    if not ok:
        sys.exit(f"Ingest reachability failed: {msg}")
    print(f"Ingest endpoint reachable ({msg})")

    if mcp:
        ok, msg = deviceflow.verify_mcp_reachable(mcp.get("url"), mcp.get("api_key"))
        if not ok:
            sys.exit(f"MCP reachability failed: {msg}")
        print(f"MCP endpoint reachable ({msg})")

    if not HOOK_SCRIPT.exists():
        sys.exit(f"Telemetry hook script is missing: {HOOK_SCRIPT}")

    # Write user-level configs FIRST — they never depend on the project.
    if mcp:
        b = write_mcp_config(USER_MCP_PATH, mcp["url"], mcp["api_key"])
        print(f"Wrote Cardinal MCP entry to {USER_MCP_PATH}")
        if b:
            print(f"MCP backup: {b}")

    write_secrets(bundle)
    print(f"Wrote Cardinal local secrets to {SECRETS_PATH}")

    b = write_hooks_config(USER_HOOKS_PATH)
    print(f"Wrote Cardinal hooks to {USER_HOOKS_PATH}")
    if b:
        print(f"Hooks backup: {b}")

    if project_paths:
        if mcp:
            b = write_mcp_config(Path(project_paths["mcp_path"]), mcp["url"], mcp["api_key"])
            print(f"Wrote Cardinal MCP entry to {project_paths['mcp_path']} (cloud-agent path)")
            if b:
                print(f"Project MCP backup: {b}")
        b = write_hooks_config(Path(project_paths["hooks_path"]))
        print(f"Wrote Cardinal hooks to {project_paths['hooks_path']} (cloud-agent path)")
        if b:
            print(f"Project hooks backup: {b}")

    write_state(bundle, args.host, deployment_env, args.telemetry_only, project_paths)
    print(f"Wrote Cardinal state to {STATE_PATH}")

    print()
    print(f"Connected as {user.get('email') or 'unknown'} ({org.get('slug') or org.get('id')})")
    print(f"Telemetry endpoint: {ingest['endpoint']}")
    if mcp:
        print(f"MCP endpoint: {mcp['url']}")
    if project_paths:
        print(f"Project install root: {project_paths['root']}")
        print(
            "Commit .cursor/mcp.json and .cursor/hooks.json to your repo so "
            "cloud agents pick them up."
        )
    print()
    print("Restart Cursor so it reloads MCP and hook config, then run cardinal-status.")
    return 0


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="cardinal-connect",
        description="Connect Cursor to Cardinal's unified MCP endpoint.",
    )
    parser.add_argument(
        "--host",
        default="https://app.cardinalhq.io",
        help="Cardinal app host (default: https://app.cardinalhq.io)",
    )
    parser.add_argument(
        "--rotate",
        action="store_true",
        help="Proceed even if Cardinal state already exists and mint a fresh key.",
    )
    parser.add_argument(
        "--telemetry-only",
        action="store_true",
        help="Only configure Cardinal telemetry hooks; skip the MCP credential.",
    )
    parser.add_argument(
        "--project",
        action="store_true",
        help=(
            "Additionally write .cursor/mcp.json and .cursor/hooks.json at the "
            "current git repository root so Cursor cloud agents (which do not "
            "load ~/.cursor/) pick up the Cardinal wiring."
        ),
    )
    parser.add_argument(
        "--deployment-env",
        default=None,
        help="Override deployment.environment (default derived from --host).",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Run the device-code flow and print what would be written.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if STATE_PATH.exists() and not args.rotate:
        try:
            prior = json.loads(STATE_PATH.read_text())
        except Exception:
            prior = {}
        user = prior.get("user_email") or "this account"
        sys.stderr.write(
            f"Cardinal is already connected as {user}. "
            "Re-run with --rotate to overwrite.\n"
        )
        return 2

    scopes = ["ingest:write"]
    if not args.telemetry_only:
        scopes.append("mcp:invoke")
    print(f"Requesting Cardinal consent for scopes: {', '.join(scopes)}")
    try:
        grant = deviceflow.start_device_code(args.host, scopes, CLIENT_ID)
    except deviceflow.DeviceFlowError as exc:
        sys.exit(str(exc))
    write_pending(grant)
    try:
        return continue_after_grant(args, grant)
    finally:
        clear_pending()


if __name__ == "__main__":
    sys.exit(main())
